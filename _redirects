# Netlify routing.
#
# Weekly cache-bust: the SMS send includes /{week} in the URL (e.g.
# menu.havnclub.com/may10, menu.havnclub.com/welcome/may10). Each week has
# a unique URL, so messaging apps (iMessage, WhatsApp) regenerate the link
# preview instead of serving the previous week's cached image. Bump the
# prefix weekly alongside the menu deploy.
#
# This rule strips the weekly prefix off static asset requests — e.g.
# /may10/menu-preview.jpg is served from /menu-preview.jpg. Customer-facing
# page URLs like /may10 or /welcome/may10 fall through to the page rewrites
# below and are detected in index.html via window.location.pathname.
/may10/*    /:splat 200

# Welcome-offer variant: same index.html, detected via isWelcomeMode from
# the pathname. Only customers who get the welcome link (via Make.com)
# hit this path; all other traffic falls through to the default rewrite.
/welcome/*  /index.html 200
/welcome    /index.html 200

# Internal weekly performance review — unguessable path, not linked from anywhere
/may10-review  /may10-review.html  200

/*          /index.html 200
